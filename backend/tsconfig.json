{
  // visit https://aka.ms/tsconfig for details
  "compilerOptions": {
    /* project layout */
    "rootDir": ".", // everything in the package is a source file
    "outDir": "./dist",

    /* language / environment */
    "target": "es2016",
    "module": "ESNext",
    // classic resolver avoids needing extensions even though we emit ESM
    "moduleResolution": "node",
    "moduleDetection": "force",

    /* node globals */
    "types": ["node"],

    /* emit */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* interoperability */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,

    /* strictness */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,

    /* misc */
    // preserve import/export syntax but modules are now ESM
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },

  /* explicitly compile the parts of the repo you care about */
  "include": [
    "src/**/*.ts", // main code
    "tests/**/*.ts", // test files
    "prisma.config.ts", // Prisma setup file
    "prisma/**/*.ts" // if you ever keep helper scripts there
  ],

  "exclude": [
    "./jest.config.ts",
    "./node_modules",
    "./build",
    "./dist",
    "./tests"
  ]
}
