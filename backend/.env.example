# ===========================================
# Variáveis de ambiente — Case Stage Backend
# ===========================================

# Porta do servidor
PORT=3333

# URL de conexão com o banco PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/case_stage?schema=public"

# Origens permitidas para CORS (separadas por vírgula)
# Deploys preview do Vercel (*.vercel.app) são aceitos automaticamente
CORS_ORIGIN="http://localhost:3000,http://localhost:5173,https://case-stage.vercel.app"

# Ambiente (development | production | test)
NODE_ENV="development"