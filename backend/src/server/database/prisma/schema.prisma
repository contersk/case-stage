generator client {
  provider = "prisma-client-js"
}

/// Gerador de documentação HTML do banco de dados.
/// Após rodar `npx prisma generate`, a documentação será criada em ./docs.
generator docs {
  provider = "node node_modules/prisma-docs-generator"
  output   = "../../../../../docs/database"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Nível de prioridade de um processo organizacional.
/// Utilizado para classificação e filtragem no dashboard.
enum process_priority {
  /// Prioridade alta — requer ação imediata
  Alta
  /// Prioridade média — acompanhamento regular
  Media
  /// Prioridade baixa — pode ser tratado posteriormente
  Baixa
}

/// Tipo de execução do processo.
enum process_type {
  /// Processo automatizado por sistema
  Sistemico
  /// Processo executado manualmente por pessoas
  Manual
}

/// Status do ciclo de vida de um processo.
enum process_status {
  /// Processo planejado, ainda não iniciado
  Planejado
  /// Processo em execução — requer atenção
  Em_Andamento
  /// Processo finalizado com sucesso
  Concluido
  /// Processo cancelado — inativo
  Cancelado
}

/// Área organizacional (ex: RH, TI, Financeiro).
/// Cada área agrupa um conjunto de processos hierárquicos.
model Area {
  id        String    @id @default(uuid()) @map("id") 
  name      String    @unique @map("name") @db.VarChar(255)
  processes Process[]
  
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("areas")
}

/// Processo organizacional com suporte a hierarquia (árvore pai-filho).
/// Cada processo pertence a uma Área e pode conter ferramentas, responsáveis e documentos.
model Process {
  id          String    @id @default(uuid()) @map("id")
  title       String    @map("title") @db.VarChar(255)
  description String?   @map("description") @db.Text
  
  // Utilizando os Enums para garantir integridade
  type        process_type     @default(Manual) @map("type")
  status      process_status   @default(Planejado) @map("status")
  priority    process_priority @default(Media) @map("priority")
  
  // Datas para futuros gráficos de Gantt ou SLAs
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")

  // Relacionamento com a Área
  areaId      String    @map("area_id")
  area        Area      @relation(fields: [areaId], references: [id], onDelete: Cascade)

  // A AUTO-REFERÊNCIA: A Árvore Hierárquica
  parentId    String?   @map("parent_id")
  parent      Process?  @relation("ProcessHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    Process[] @relation("ProcessHierarchy")

  // Tabelas Normalizadas (Melhor que campos de texto soltos)
  tools        Tool[]
  responsibles Responsible[]
  documents    Document[]

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([areaId])
  @@index([parentId])
  @@map("processes")
}

/// Ferramenta/sistema utilizado na execução de um processo.
model Tool {
  id        String  @id @default(uuid()) @map("id")
  name      String  @map("name") @db.VarChar(255)
  
  processId String  @map("process_id")
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
  @@map("tools")
}

/// Pessoa responsável por um processo, com cargo/função opcional.
model Responsible {
  id        String  @id @default(uuid()) @map("id")
  name      String  @map("name") @db.VarChar(255)
  role      String? @map("role") @db.VarChar(255)
  
  processId String  @map("process_id")
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
  @@map("responsibles")
}

/// Documento associado a um processo (manuais, procedimentos, links externos).
model Document {
  id        String  @id @default(uuid()) @map("id")
  title     String  @map("title") @db.VarChar(255)
  url       String? @map("url") @db.Text
  
  processId String  @map("process_id")
  process   Process @relation(fields: [processId], references: [id], onDelete: Cascade)

  @@index([processId])
  @@map("documents")
}